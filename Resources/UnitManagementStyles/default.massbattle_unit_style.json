{
  "schema_version": 1,
  "id": "default",
  "display_name": "Default MassBattle Unit Management Style",
  "description": "Default style profile for compact unit queries, balance export, and generated asset organization.",
  "default_scan_roots": [
    "/MassBattle",
    "/Game/Unit",
    "/Game/Toon_Soldiers_WW2",
    "/Game/StylizedArmyPackA",
    "/Game/World_Flags"
  ],
  "project_scan_roots": [
    "/Game/Unit",
    "/Game/Toon_Soldiers_WW2",
    "/Game/StylizedArmyPackA",
    "/Game/World_Flags"
  ],
  "simple_top_level_fields": [
    "SubType",
    "StyleType",
    "Scaling",
    "Collider",
    "PhysicsShared",
    "Health",
    "Move",
    "Attack",
    "Damage",
    "Defence",
    "Trace",
    "Visualize",
    "LODShared",
    "AnimShared"
  ],
  "default_export_fields": [
    "StyleType.Index",
    "SubType.Index",
    "Health.Maximum",
    "Health.Current",
    "Move.MovementModel",
    "Move.XY.MoveSpeed",
    "Move.XY.MoveAcceleration",
    "Move.XY.AcceptanceRadius",
    "Attack.bEnable",
    "Attack.Range",
    "Attack.CoolDown",
    "Attack.DurationPerRound",
    "Damage.Damage",
    "Damage.DmgRadius",
    "Defence.NormalDmgImmune",
    "Collider.Radius",
    "Collider.Height",
    "Collider.Mass"
  ],
  "organization": {
    "target_root": "/Game/Unit/Actor",
    "trash_root": "/Game/_Trash/MassBattle/Units",
    "families": {
      "infantry": {
        "folder": "Army/Soldier",
        "keywords": ["soldier", "infantry", "human", "japan", "soviet", "china", "chinese", "brit", "german", "us", "ww2", "toon"]
      },
      "officer": {
        "folder": "Army/Officer",
        "keywords": ["officer", "commander", "leader"]
      },
      "armored": {
        "folder": "Army/Tank",
        "keywords": ["tank", "apc", "vehicle"]
      },
      "air": {
        "folder": "Aircraft",
        "keywords": ["helicopter", "fighter", "jet", "aircraft"]
      },
      "building": {
        "folder": "Building",
        "keywords": ["camp", "spawner", "building", "city", "flag"]
      }
    }
  },
  "batch_fx_defaults": {
    "generated_root": "/Game/MassBattleGenerated/BatchFx",
    "trash_root": "/Game/_Trash/MassBattle/Assets",
    "renderer_blueprint_prefix": "BP_FxRenderer_",
    "niagara_system_prefix": "NS_FxRenderer_",
    "default_ndc_burst_fx": "/MassBattle/Core/FxRenderer/NS_Modules/NDC_BurstFx.NDC_BurstFx",
    "default_style": "Style0",
    "default_render_batch_size": 4096,
    "default_pooling_cooldown": 10,
    "default_fixed_bounds": "(IsValid=True,Min=(X=-50000.000000,Y=-50000.000000,Z=-50000.000000),Max=(X=50000.000000,Y=50000.000000,Z=50000.000000))",
    "manual_level_actor_policy": "MCP configures reusable renderer Blueprint assets; the user manually places the actor in a level."
  },
  "batch_fx_templates": {
    "mesh_burst_hit": {
      "description": "Visible Niagara MeshRenderer burst for proving batched hit events before final art.",
      "source_niagara": "/MassBattle/Demo/Projectile/Batched/Rocket/Renderer/NS_FxRenderer_Rocket.NS_FxRenderer_Rocket",
      "source_renderer_blueprint": "/MassBattle/Demo/Projectile/Batched/Rocket/Renderer/BP_FxRenderer_Rocket.BP_FxRenderer_Rocket",
      "ndc_burst_fx": "/MassBattle/Core/FxRenderer/NS_Modules/NDC_BurstFx.NDC_BurstFx",
      "keep_emitters": ["Muzzle"],
      "disable_emitters": ["Core", "Hit", "Trail"],
      "renderer_kind": "NiagaraMeshRendererProperties",
      "batch_mode": "burst",
      "recommended_unit_fields": ["Hit.SpawnFx", "Death.SpawnFx"],
      "recommended_transform": "(Rotation=(X=0.000000,Y=0.000000,Z=0.000000,W=1.000000),Translation=(X=0.000000,Y=0.000000,Z=280.000000),Scale3D=(X=30.000000,Y=30.000000,Z=30.000000))",
      "recommended_quantity": 8,
      "recommended_lifespan": 2
    },
    "sprite_explosion_burst": {
      "description": "Existing batched explosion reference; useful for fire/explosion remakes.",
      "source_niagara": "/MassBattle/Demo/SharedFx/Explosion/Batched/NS_FxRenderer_Explosion.NS_FxRenderer_Explosion",
      "source_renderer_blueprint": "/MassBattle/Demo/SharedFx/Explosion/Batched/BP_FxRenderer_Explosion.BP_FxRenderer_Explosion",
      "ndc_burst_fx": "/MassBattle/Demo/SharedFx/Explosion/Batched/NDC_Explosion.NDC_Explosion",
      "renderer_kind": "NiagaraSpriteRendererProperties",
      "batch_mode": "burst",
      "recommended_unit_fields": ["Death.SpawnFx", "Hit.SpawnFx"],
      "note": "Keep the renderer CDO NDC matching the Niagara graph; this template does not use the core NDC_BurstFx asset."
    },
    "projectile_muzzle_burst": {
      "description": "Batched projectile muzzle reference for attack/muzzle FX.",
      "source_niagara": "/MassBattle/Demo/Projectile/Batched/Bullet/Renderer/NS_FxRenderer_Bullet.NS_FxRenderer_Bullet",
      "source_renderer_blueprint": "/MassBattle/Demo/Projectile/Batched/Bullet/Renderer/BP_FxRenderer_Bullet.BP_FxRenderer_Bullet",
      "ndc_burst_fx": "/MassBattle/Core/FxRenderer/NS_Modules/NDC_BurstFx.NDC_BurstFx",
      "keep_emitters": ["Muzzle"],
      "renderer_kind": "NiagaraMeshRendererProperties",
      "batch_mode": "burst",
      "recommended_unit_fields": ["Attack.SpawnFx"]
    }
  },
  "authoring_defaults": {
    "recipe_id": "vat_skeletal_unit",
    "default_unit_template": "",
    "source_folder_name": "Source_{asset_slug}",
    "generated_folder_name": "Gen_{asset_slug}",
    "unit_asset_prefix": "AgentConfig_",
    "renderer_prefix": "Renderer_",
    "static_mesh_prefix": "SM_",
    "vat_data_prefix": "VAT_",
    "material_prefix": "",
    "animation_search_roots": [
      "/Game/Unit",
      "/Game/Toon_Soldiers_WW2/Animations",
      "/Game/StylizedArmyPackA/Soldiers_Animations",
      "/Game/StylizedArmyPackA/Flags_Actors",
      "/MassBattle/Demo",
      "/MassBattle/Test"
    ]
  }
}
